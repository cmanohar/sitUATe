{
  "name": "@situate/server",
  "version": "0.1.0",
  "description": "Situate collector seed: Vite dev plugin + standalone ingest service. Sprint 2 evolves this into a Fastify service with pluggable storage.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./collector": "./src/collector.mjs"
  },
  "files": ["dist", "src/collector.mjs"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "collect": "node src/collector.mjs"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  }
}
