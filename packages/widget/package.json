{
  "name": "@cmanohar/flow-feedback",
  "version": "0.1.0",
  "description": "Embeddable React feedback + UAT overlay widget. Self-contained, theme-able, PHI-redaction-ready.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./preset": "./flow-preset.cjs"
  },
  "files": ["dist", "flow-preset.cjs"],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:css",
    "build:css": "tailwindcss -c tailwind.config.cjs -i src/theme.css -o dist/styles.css --minify",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@cmanohar/flow-core": "0.1.0",
    "lucide-react": "^0.441.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
